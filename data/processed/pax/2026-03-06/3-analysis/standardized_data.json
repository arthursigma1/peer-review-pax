  "fre_definition_notes": {
    "BX": "FRE = management fees + fee-related revenues - operating expenses (excl. performance-related comp). Includes transaction advisory fees. SBC deducted. FY2024 FRE $5.3B.",
    "APO": "FRE = fee-related revenues (management fees + transaction fees) - fee-related compensation - other operating expenses. Excludes Athene retirement services segment for FRE purposes but includes it for adjusted net income/DE.",
    "KKR": "FRE = total management fees + transaction/monitoring fees - management fee-related expenses. KKR uses 'Fee Related Earnings' as reported. Includes Global Atlantic insurance segment management fees in broader metrics.",
    "BAM": "FRE = base management fees + catch-up and transaction fees - direct costs. Reported by Brookfield Asset Management (pure-play manager spin-off). FRE margin of 73% is highest in sample.",
    "ARES": "FRE = management fees + other fee income - compensation and benefits - G&A. Excludes performance income entirely. FRE margin of 41.5% reflects higher compensation structure.",
    "CG": "FRE = fund management fees + portfolio advisory fees - cash-based compensation - G&A. Significant margin expansion in FY2024 (+900bps) driven by cost discipline. FRE cash comp ratio improved to 36%.",
    "OWL": "FRE = management fees + administrative fees - compensation (excl SBC) - G&A. 91% of management fees from permanent capital vehicles. Minimal performance fee component.",
    "TPG": "FRE = fee-related revenues (includes monitoring fees from Angelo Gordon) - fee-related compensation - other expenses. IPO in Jan 2022; equity-based comp from IPO depresses GAAP but not FRE.",
    "EQT": "Uses 'Fee-Related EBITDA' as proxy for FRE. Includes management fees and fund admin fees, excludes carried interest. Reported in EUR, converted at 1.07 EUR/USD. FRE margin of 53%.",
    "STEP": "FRE = management and advisory fee revenue - fee-related compensation - G&A. March fiscal year end (FY2025 = Apr 2024 - Mar 2025). FRE margin mid-30s, lower due to solutions-oriented model.",
    "HLNE": "FRE = management and advisory fees - compensation - G&A. March fiscal year end (FY2025 = Apr 2024 - Mar 2025). FRE margin 53.8%, higher than STEP due to product mix.",
    "ICP": "Does not report FRE; uses 'FMC operating profit' as closest proxy. March fiscal year end. FEAUM and EV/FEAUM available but P/FRE cannot be directly computed. Included with EV/FEAUM only.",
    "GCMG": "FRE = private markets management fees + absolute return strategy fees - fee-related expenses. Private markets FRE margin 44%. Fund-of-funds model.",
    "BPT": "Uses 'underlying EBITDA' as FRE proxy. Pro forma figures include ECP acquisition completed in 2024. FRE margin 72.3% reflects asset-light European model.",
    "TKO": "Reports FRE as defined metric. FRE margin 33% in FY2024. EUR-denominated, converted at 1.07. European multi-strategy credit-focused model.",
    "PAX": "FRE = management fees + fund administration fees - compensation - G&A. USD-denominated. FRE margin 57%. LatAm-focused with growing global platform via acquisitions.",
    "PX": "FRE = fee-related revenue - fee-related compensation - operating expenses. All AUM is fee-paying. FRE margin 48.8%. Lower-middle market PE/VC solutions model.",
    "RF": "FRE = management fees + subscription line fees - operating expenses. EUR-denominated, converted at 1.07. Hybrid model includes balance sheet investments (EUR 9.9B). FRE margin 35.5%.",
    "ANTIN": "Uses 'underlying EBITDA' as FRE proxy. Pure-play infrastructure GP. EUR-denominated, converted at 1.07. FRE margin 59%. No carried interest revenue in FY2024.",
    "BN": "FRE figure represents BAM segment only ($2.5B). BN market cap ($93.9B) includes insurance, principal investments, and operating businesses — P/FRE and P/DE are NOT pure AM multiples. Included with low confidence flag.",
    "VCTR": "Uses 'adjusted EBITDA' as FRE proxy. Traditional/multi-boutique AM, not alternative-focused. Revenue is 100% management fees (no carry). FRE margin 53.2%.",
    "CVC": "Reports 'Management Fee Earnings' (MFE) as FRE equivalent. EUR-denominated, converted at 1.07. MFE margin 59%. IPO'd April 2024; first full FY as public company."
