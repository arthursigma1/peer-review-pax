{
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "claude",
          "cmd": "claude",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "shell:allow-open",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:default",
    "dialog:default",
    "notification:default"
  ]
}
