{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VDA PAX Lens",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "target_company",
    "target_ticker",
    "ranked_recommendations",
    "decision_risks",
    "governance_cascade"
  ],
  "properties": {
    "target_company": { "type": "string" },
    "target_ticker": { "type": "string" },
    "ranked_recommendations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "play_id",
          "priority_rank",
          "why_this_matters_for_pax",
          "what_must_be_true",
          "why_this_may_fail_for_pax",
          "feasibility_horizon"
        ],
        "properties": {
          "play_id": { "type": "string" },
          "priority_rank": { "type": "integer", "minimum": 1 },
          "why_this_matters_for_pax": { "type": "string", "minLength": 1 },
          "what_must_be_true": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "why_this_may_fail_for_pax": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "feasibility_horizon": {
            "type": "string",
            "enum": ["near_term_feasible", "medium_term_feasible", "aspirational"]
          }
        }
      }
    },
    "decision_risks": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "governance_cascade": {
      "type": "object",
      "additionalProperties": false,
      "required": ["board", "management", "business_units"],
      "properties": {
        "board": { "type": "array", "items": { "type": "string" } },
        "management": { "type": "array", "items": { "type": "string" } },
        "business_units": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
