{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VDA Playbook Entry",
  "description": "A single PLAY-NNN or ANTI-NNN entry in the platform_playbook.json or asset_class_playbooks.json. Accepts both PascalCase field names (SKILL.md mandatory fields) and snake_case field names (actual agent output).",
  "type": "object",
  "additionalProperties": true,
  "required": [],
  "oneOf": [
    {
      "description": "Entry has play_id (canonical lowercase form)",
      "required": ["play_id"]
    },
    {
      "description": "Entry has Play_ID (PascalCase legacy form)",
      "required": ["Play_ID"]
    },
    {
      "description": "Entry has anti_id (anti-pattern form)",
      "required": ["anti_id"]
    }
  ],
  "properties": {
    "play_id": { "type": "string" },
    "Play_ID": { "type": "string" },
    "anti_id": { "type": "string" },
    "play_name": { "type": "string" },
    "anti_name": { "type": "string" },
    "description": { "type": "string" },

    "What_Was_Done": { "type": "string", "minLength": 1 },
    "Observed_Metric_Impact": { "type": "string", "minLength": 1 },
    "Prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "Preconditions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "Operational_And_Tech_Prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "Execution_Burden": { "type": "string", "minLength": 1 },
    "Time_To_Build": { "type": "string", "minLength": 1 },
    "Margin_Risk": { "type": "string", "minLength": 1 },
    "Failure_Modes_And_Margin_Destroyers": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "Transferability_Constraints": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "Archetype_Relevance": { "type": "string" },
    "Evidence_Strength": {
      "type": "string",
      "enum": ["high", "moderate", "directional", "unsupported", "low"]
    },
    "Recommendation_For_PAX": { "type": "string" },

    "what_was_done": { "type": "string", "minLength": 1 },
    "metric_impact": { "type": "string", "minLength": 1 },
    "prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "risks_limitations": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },

    "firms_executed": {
      "type": "array",
      "items": { "type": "string" }
    },
    "firms_attempted": {
      "type": "array",
      "items": { "type": "string" }
    },
    "action_citations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source_citations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "negative_outcome": { "type": "string" },
    "why_it_failed": { "type": "string" },

    "PAX_Relevance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scale_fit",
        "geography_fit",
        "client_distribution_fit",
        "balance_sheet_fit",
        "regulatory_fit",
        "operating_model_fit",
        "tech_readiness",
        "data_reporting_readiness",
        "time_to_build",
        "capital_intensity",
        "margin_risk",
        "execution_complexity",
        "feasibility_horizon"
      ],
      "properties": {
        "scale_fit": { "type": "integer", "minimum": 1, "maximum": 5 },
        "geography_fit": { "type": "integer", "minimum": 1, "maximum": 5 },
        "client_distribution_fit": { "type": "integer", "minimum": 1, "maximum": 5 },
        "balance_sheet_fit": { "type": "integer", "minimum": 1, "maximum": 5 },
        "regulatory_fit": { "type": "integer", "minimum": 1, "maximum": 5 },
        "operating_model_fit": { "type": "integer", "minimum": 1, "maximum": 5 },
        "tech_readiness": { "type": "integer", "minimum": 1, "maximum": 5 },
        "data_reporting_readiness": { "type": "integer", "minimum": 1, "maximum": 5 },
        "time_to_build": { "type": "integer", "minimum": 1, "maximum": 5 },
        "capital_intensity": { "type": "integer", "minimum": 1, "maximum": 5 },
        "margin_risk": { "type": "integer", "minimum": 1, "maximum": 5 },
        "execution_complexity": { "type": "integer", "minimum": 1, "maximum": 5 },
        "feasibility_horizon": {
          "type": "string",
          "enum": ["near_term_feasible", "medium_term_feasible", "aspirational"]
        }
      }
    }
  }
}
