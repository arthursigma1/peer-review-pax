{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VDA Strategic Action",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "action_id",
    "firm_ticker",
    "strategy_sub_type",
    "thematic_focus",
    "economic_model",
    "what_was_done",
    "observed_metric_impact",
    "operational_prerequisites"
  ],
  "properties": {
    "action_id": { "type": "string" },
    "firm_ticker": { "type": "string" },
    "strategy_sub_type": { "type": "string" },
    "thematic_focus": { "type": "string" },
    "economic_model": { "type": "string" },
    "what_was_done": { "type": "string", "minLength": 1 },
    "observed_metric_impact": { "type": "string", "minLength": 1 },
    "operational_prerequisites": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requirement",
          "evidence_class",
          "source_bias_tag",
          "confidence_level",
          "stated_or_inferred"
        ],
        "properties": {
          "requirement": { "type": "string", "minLength": 1 },
          "evidence_class": {
            "type": "string",
            "enum": ["directly_stated", "corroborated", "inferred"]
          },
          "source_bias_tag": {
            "type": "string",
            "enum": [
              "regulatory-filing",
              "company-produced",
              "third-party-analyst",
              "journalist",
              "industry-report",
              "peer-disclosure",
              "supporting-low-trust"
            ]
          },
          "confidence_level": {
            "type": "string",
            "enum": ["high", "moderate", "low"]
          },
          "stated_or_inferred": {
            "type": "string",
            "enum": ["stated", "inferred"]
          }
        }
      }
    }
  }
}
